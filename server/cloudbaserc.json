{
  "envId": "{{env.CLOUDBASE_ENV_ID}}",
  "version": "2.0",
  "$schema": "https://framework-1258016615.tcloudbaseapp.com/schema/latest.json",
  "framework": {
    "name": "skin-analysis-backend",
    "plugins": {}
  },
  "services": [
    {
      "name": "nestjs-server",
      "type": "container",
      "containerPort": 3000,
      "cpu": 0.5,
      "mem": 1.0,
      "minNum": 0,
      "maxNum": 10,
      "dockerfile": "./Dockerfile",
      "envVariables": {
        "COZE_API_KEY": "{{env.COZE_API_KEY}}",
        "COZE_MODEL": "doubao-vision",
        "CLOUDBASE_ENV_ID": "{{env.CLOUDBASE_ENV_ID}}",
        "NODE_ENV": "production"
      },
      "customLogs": "./logs",
      "volumeMounts": []
    }
  ]
}
